{{!< default}}

<main class="site-main post-main">
    <article class="{{post_class}}">
        {{#post}}

        <div class="post-layout">

            {{#if @page.show_title_and_feature_image}}
            <header class="post-header">
                <h1 class="post-title fade-up">{{title}}</h1>
                {{#if custom_excerpt}}
                <p class="post-subtitle fade-up" style="transition-delay:.05s">{{custom_excerpt}}</p>
                {{/if}}
            </header>

            {{#if feature_image}}
            <figure class="post-feature-image fade-up">
                <img
                    src="{{img_url feature_image size="lg"}}"
                    alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                    loading="eager">
                {{#if feature_image_caption}}
                <figcaption>{{feature_image_caption}}</figcaption>
                {{/if}}
            </figure>
            {{/if}}
            {{/if}}

            <div class="post-content-wrap fade-up">
                <section class="post-content gh-content">
                    {{content}}
                </section>
            </div>

        </div>

        {{/post}}
    </article>
</main>
