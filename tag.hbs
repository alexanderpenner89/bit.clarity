{{!< default}}

<main class="site-main tag-main">
    <div class="container">

        <header class="tag-header">
            {{#tag}}
            <p class="tag-eyebrow fade-up">Gewerk</p>
            <h1 class="tag-title fade-up" style="transition-delay:.04s">{{name}}</h1>
            {{#if description}}
            <p class="tag-description fade-up" style="transition-delay:.08s">{{description}}</p>
            {{/if}}
            {{/tag}}
        </header>

        <div class="posts-feed tag-feed">
            {{#foreach posts}}
            <article class="feed-item {{post_class}}">
                <a href="{{url}}" class="feed-item-link">
                    <div class="feed-item-image">
                        {{#if feature_image}}
                        <img src="{{img_url feature_image size="md"}}" alt="{{title}}" loading="lazy">
                        {{else}}
                        <div class="feed-item-placeholder">
                            {{#if primary_tag}}<span>{{primary_tag.name}}</span>{{else}}<span>Dossier</span>{{/if}}
                        </div>
                        {{/if}}
                    </div>
                    <div class="feed-item-body">
                        <h3 class="feed-item-title">{{title}}</h3>
                        {{#if excerpt}}
                        <p class="feed-item-excerpt">{{excerpt words="20"}}</p>
                        {{/if}}
                        <div class="feed-item-meta">
                            <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD. MMMM YYYY"}}</time>
                        </div>
                    </div>
                </a>
            </article>
            {{/foreach}}
        </div>

        {{> "pagination"}}

    </div>
</main>
