<header class="site-header" id="site-header">
    <div class="container">
        <div class="header-inner">
            <a href="{{@site.url}}" class="site-logo" aria-label="{{@site.title}} – Startseite">
                <span class="logo-mark" aria-hidden="true">bt</span>
                <span class="logo-text">bit.transfer</span>
            </a>
            <nav class="site-nav" aria-label="Hauptnavigation">
                {{#foreach @site.navigation}}
                <a href="{{this.url}}" class="{{link_class for=this.url}}">{{label}}</a>
                {{/foreach}}
            </nav>
            <button class="nav-mobile-btn" aria-label="Navigation" aria-expanded="false" id="nav-mobile-btn">
                <span></span>
                <span></span>
            </button>
        </div>
    </div>
</header>
