{{!< default}}

<main class="site-main post-main">
    {{#post}}

    <div class="post-layout">

        {{! ── Header ── }}
        <header class="post-header">
            {{#if tags}}
            <div class="post-tags fade-up">
                {{#foreach tags limit="4"}}
                <a href="{{url}}" class="post-tag-pill">{{name}}</a>
                {{/foreach}}
            </div>
            {{/if}}

            <h1 class="post-title fade-up" style="transition-delay:.05s">{{title}}</h1>

            {{#if custom_excerpt}}
            <p class="post-subtitle fade-up" style="transition-delay:.08s">{{custom_excerpt}}</p>
            {{/if}}

            <div class="post-meta fade-up" style="transition-delay:.1s">
                <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD. MMMM YYYY"}}</time>
                <span class="post-meta-dot">·</span>
                <span>{{reading_time}}</span>
                {{#if primary_author}}
                <span class="post-meta-dot">·</span>
                <span>{{primary_author.name}}</span>
                {{/if}}
            </div>
        </header>

        {{! ── Feature Image ── }}
        {{#if feature_image}}
        <figure class="post-feature-image fade-up">
            <img
                src="{{img_url feature_image size="lg"}}"
                alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                loading="eager">
            {{#if feature_image_caption}}
            <figcaption>{{feature_image_caption}}</figcaption>
            {{/if}}
        </figure>
        {{/if}}

        {{! ── Content ── }}
        <div class="post-content-wrap fade-up">
            <section class="post-content gh-content">
                {{content}}
            </section>

            <footer class="post-footer">
                <nav class="post-navigation" aria-label="Artikel-Navigation">
                    {{#prev_post}}
                    <a href="{{url}}" class="nav-post nav-prev">
                        <span class="nav-label">← Vorheriger Artikel</span>
                        <span class="nav-title">{{title}}</span>
                    </a>
                    {{/prev_post}}
                    {{#next_post}}
                    <a href="{{url}}" class="nav-post nav-next">
                        <span class="nav-label">Nächster Artikel →</span>
                        <span class="nav-title">{{title}}</span>
                    </a>
                    {{/next_post}}
                </nav>
            </footer>
        </div>

    </div>

    {{/post}}
</main>
